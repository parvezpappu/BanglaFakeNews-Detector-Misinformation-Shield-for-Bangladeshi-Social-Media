*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Local secrets and environment files
.env
.env.*
!.env.example

# Frontend dependencies and build outputs
app/frontend/node_modules/
app/frontend/dist/
app/frontend/.vite/
app/frontend/.vite-temp/
